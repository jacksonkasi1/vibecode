# Database - Must match your server's database URL
DATABASE_URL="postgresql://user:password@localhost:5432/flowstack"

# Worker Settings
WORKSPACE_DIR="/tmp/vibecode-workspaces"
POLL_INTERVAL_MS="500"

# AI Provider
# IMPORTANT: You need to add this to your apps/server/.env as well!
GEMINI_API_KEY="your_api_key_here"

# R2 Configuration (For artifact uploads)
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT_URL="https://your-account-id.r2.cloudflarestorage.com"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_URL="https://your-public-domain.com"

# Dispatch (Pub/Sub)
# poller | pubsub
WORKER_DISPATCH_MODE="pubsub"
PUBSUB_PROJECT_ID="your-gcp-project-id"
PUBSUB_EXECUTIONS_SUBSCRIPTION="vibecode-worker-executions-v1"
PUBSUB_ENABLE_POLLER_FALLBACK="false"
GOOGLE_APPLICATION_CREDENTIALS="../../.secrets/gcp-service-account.json"
