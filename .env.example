# ===========================================
# FlowStack Environment Variables
# ===========================================

# ===========================================
# Server Configuration
# ===========================================
PORT=8080
NODE_ENV=development

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info              # debug | info | warn | error

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# API Authentication (optional)
# ===========================================
API_SECRET_KEY=

# ===========================================
# Database
# ===========================================
DATABASE_URL=

# ===========================================
# Third-party Services (add as needed)
# ===========================================
# EXTERNAL_API_KEY=

# ===========================================
# Execution Dispatch (optional)
# ===========================================
# Server: local_polling | pubsub
EXECUTION_DISPATCH_MODE=pubsub
PUBSUB_PROJECT_ID=your-gcp-project-id
PUBSUB_EXECUTIONS_TOPIC=vibecode-executions-v1
GOOGLE_APPLICATION_CREDENTIALS=../../.secrets/gcp-service-account.json
EXECUTION_STREAM_POLL_MS=250

# Worker: poller | pubsub
WORKER_DISPATCH_MODE=pubsub
PUBSUB_EXECUTIONS_SUBSCRIPTION=vibecode-worker-executions-v1
PUBSUB_ENABLE_POLLER_FALLBACK=false
POLL_INTERVAL_MS=500
